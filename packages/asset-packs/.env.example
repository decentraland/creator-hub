# Example credentials for the asset-pack S3 upload scripts against a local MinIO
# instance (see docker-compose.yml). Copy to .env and adjust as needed.
AWS_ACCESS_KEY_ID=admin
AWS_SECRET_ACCESS_KEY=password
S3_BUCKET_NAME=asset-packs
S3_REGION=us-east-1
S3_UPLOAD_CONCURRENCY=20
AWS_STORAGE_URL=http://0.0.0.0:9000