{
  "permissions": {
    "allow": [
      "Bash(cat > *)",
      "Bash(npm --workspace @dcl/inspector run typecheck)",
      "Bash(npm --workspace @dcl/inspector run test)",
      "Bash(npm --workspace @dcl/asset-packs run typecheck)",
      "Bash(make typecheck *)"
    ],
    "additionalDirectories": ["/tmp"]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "EnterWorktree",
        "hooks": [
          {
            "type": "command",
            "command": "make init && make test",
            "timeout": 600,
            "statusMessage": "Setting up worktree environment (install, protoc, build, test)..."
          }
        ]
      }
    ]
  }
}
